POSTGRES_DB=theme_heat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg2://postgres:change_me@postgres:5432/theme_heat
API_PREFIX=/api
APP_ENV=production
CORS_ORIGINS=http://localhost,http://127.0.0.1,https://your-domain.com
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_CRON_DAY_OF_WEEK=*
SCHEDULER_CRON_HOUR=20
SCHEDULER_CRON_MINUTE=30
SCHEDULER_SKIP_NON_TRADING_DAYS=true
FULL_SYNC_ENABLED=true
FULL_SYNC_CRON_DAY_OF_WEEK=fri
FULL_SYNC_CRON_HOUR=21
FULL_SYNC_CRON_MINUTE=30
DEFAULT_THEME_TYPES=industry,concept
RANKING_LIMIT=20
STRONG_SCORE_THRESHOLD=65
COMPUTE_BATCH_SIZE=10
COMPUTE_BATCH_PAUSE_SECONDS=0.3
INTERNAL_API_BASE_URL=http://backend:8000/api
NEXT_PUBLIC_API_BASE_PATH=/api
